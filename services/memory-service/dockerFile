# Stage 1: Build and Install Dependencies
FROM node:20-alpine AS builder

# Set the working directory to the root of the monorepo
WORKDIR /app

# Copy package files for the specific service and its internal dependencies
COPY services/memory-service/package*.json ./services/memory-service/
COPY services/event-bus/package*.json ./services/event-bus/
COPY shared/package*.json ./shared/

# Install all dependencies including those for shared folders
RUN cd shared && npm install && cd ../services/event-bus && npm install && cd ../memory-service && npm install

# Copy the actual source code for the shared folders and the service
COPY shared/ ./shared/
COPY services/event-bus/ ./services/event-bus/
COPY services/memory-service/ ./services/memory-service/

# Stage 2: Final Production Image
FROM node:20-alpine
WORKDIR /app

# Copy only the necessary installed modules and code from the builder
COPY --from=builder /app ./

# Expose the port (Render's Free Tier requires a port even for workers)
EXPOSE 10000

# Set the working directory to the specific service to run it
WORKDIR /app/services/memory-service

# Start the application
CMD ["node", "index.js"]